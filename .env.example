# ─────────────────────────────────────────────────────────────
#  Copy this file to ".env" and fill in your own values.
#  See README.md for where each value comes from.
# ─────────────────────────────────────────────────────────────

# ── Claude (Anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Default is a good balance of cost and date/time reasoning.
# Cheaper option: claude-haiku-4-5   Most capable: claude-opus-4-8
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google OAuth (Calendar only) ─────────────────────────────
# From Google Cloud Console > APIs & Services > Credentials.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
# Must EXACTLY match an "Authorized redirect URI" on your OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:5555

# Leave blank locally. On a headless host (e.g. Render), set this to the full
# contents of the google-token.json you generate with `npm run auth` locally,
# instead of shipping the file. If set, it takes priority over the file.
GOOGLE_TOKEN_JSON=

# Which calendar to add appointments to ("primary" = your main one,
# or paste a specific calendar ID from Calendar settings).
GOOGLE_CALENDAR_ID=primary

# ── Owner line (the shop owner's Google Voice conversation) ──
# Only messages from this number are treated as owner input (approvals,
# clarifications). Stored normalized to 10 digits. Defaults to 732-822-8376.
OWNER_PHONE_NUMBER=7328228376

# ── Google Voice browser automation ──────────────────────────
# Persistent Chromium profile directory (seed it locally with `npm run seed-profile`).
GV_PROFILE_PATH=./.gv-profile
# Where downloaded image attachments are stored.
MEDIA_PATH=./media
# Where diagnostic screenshots are written when automation gets stuck.
DIAGNOSTICS_PATH=./diagnostics
# Start TRUE. The service parses and routes but never sends until you flip this
# to false after verifying inbox parsing and recipient selection live.
OBSERVATION_MODE=true
# How often (seconds) to poll the Google Voice inbox.
POLL_INTERVAL_SECONDS=60
# Max outbound messages per minute (rate limit).
SEND_RATE_PER_MINUTE=6
# How many times a single outbound send is retried before failing.
MAX_SEND_RETRIES=5

# ── Media safety + retention ─────────────────────────────────
# Days to keep downloaded media before retention cleanup removes it.
MEDIA_RETENTION_DAYS=90
# Max images attached to one Claude vision request.
MAX_IMAGES_PER_MESSAGE=4
# Max accepted attachment size in bytes (default 5 MB).
MAX_ATTACHMENT_BYTES=5242880

# ── Dashboard authentication ─────────────────────────────────
# Credentials for the protected dashboard / API / media routes.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me

# ── Shop / scheduling settings ───────────────────────────────
SHOP_NAME=Joe's Auto
# IANA timezone used to interpret "Tuesday at 2" etc.
SHOP_TIMEZONE=America/New_York
# Default appointment length when the customer doesn't say.
DEFAULT_APPOINTMENT_MINUTES=60
# How often the scanner runs (cron syntax). Default: every 5 minutes.
CRON_SCHEDULE=*/5 * * * *
# How many back-and-forth clarification texts before giving up.
MAX_CLARIFICATION_ROUNDS=3

# ── App ──────────────────────────────────────────────────────
PORT=3000
DB_PATH=./data.db
TOKEN_PATH=./google-token.json
PUBLIC_URL=
